# Windows Environment Configuration
# Generated for Windows 11

# Core paths
set PLUGIN_FREEDOM_DIR=%~dp0
set PYTHON=%PLUGIN_FREEDOM_DIR%venv\Scripts\python.exe
set JUCE_ROOT=%PLUGIN_FREEDOM_DIR%\..\..\C\JUCE
set CMAKE=%PLUGIN_FREEDOM_DIR%\..\..\Program Files\CMake\bin\cmake.exe

# Add to PATH
set PATH=%PLUGIN_FREEDOM_DIR%;%PLUGIN_FREEDOM_DIR%node_modules\.bin;%PATH%

# Platform detection
set PLATFORM=win32

# Verify
@echo Environment: %PLATFORM%
@echo Python: %PYTHON%
@echo CMake: %CMAKE%